# Copy to `.env` in this folder (same directory as docker-compose.yml).
# Docker Compose reads these for variable substitution and frontend build args.

# Browser Origin for your deployed UI (CORS + MS logout redirect). Override if your EC2 IP/domain changes.
CLIENT_URL=http://18.232.85.119

# Frontend build-time (Vite); rebuild frontend image after any change.
VITE_API_BASE_URL=http://18.232.85.119:5001
VITE_APP_ORIGIN=http://18.232.85.119

# HTTP EC2: keep Microsoft off in the bundle; email/password login only.
VITE_AUTH_MODE=local-only
