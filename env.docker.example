# Copy to `.env` in this folder (same directory as docker-compose.yml).
# Docker Compose reads these for variable substitution and frontend build args.
#
# Full stack on EC2 (Docker): open the app in the browser as http://YOUR_PUBLIC_IP
# (compose maps frontend to port 80). Do not use http://localhost:5173 for that —
# that is only from `npm run dev` on your laptop (a different origin than the EC2 UI).

# Browser Origin for your deployed UI (CORS + MS logout redirect). Override if your EC2 IP/domain changes.
CLIENT_URL=http://18.232.85.119

# Optional extra CORS allowlist (comma-separated). Compose already sets a default for this IP.
# CORS_ORIGINS=http://18.232.85.119,http://18.232.85.119:80

# Frontend build-time (Vite); rebuild frontend image after any change.
VITE_API_BASE_URL=http://18.232.85.119:5001
VITE_APP_ORIGIN=http://18.232.85.119

# HTTP EC2: keep Microsoft off in the bundle; email/password login only.
VITE_AUTH_MODE=local-only

# Optional. Local Docker defaults to 5433 to avoid native macOS PostgreSQL on 5432.
# On EC2 you can leave this unset or set POSTGRES_HOST_PORT=5432 if you need host access.
# POSTGRES_HOST_PORT=5432
