# Copy to backend/.env (do not commit real secrets).

PORT=5001
NODE_ENV=production

# DB_HOST:
# - `postgres` = only inside Docker Compose (service name resolves on the app-network).
# - Laptop par `npm run dev`: `localhost` (pehle Postgres chalao, e.g. repo root se `docker compose up -d postgres` taake port 5432 host par open ho).
DB_HOST=postgres
DB_PORT=5432
DB_NAME=timesheet
DB_USER=appuser
DB_PASSWORD=apppass

APP_JWT_SECRET=change-me-to-a-long-random-string

# Optional: comma-separated extra allowed origins (merged with CLIENT_URL). Never use * with credentials.
# CORS_ORIGINS=http://18.232.85.119,http://localhost:5173

# Prefer setting CLIENT_URL via repo-root `.env` for compose (overrides this line), or set real URL here:
CLIENT_URL=http://YOUR_PUBLIC_HOST_OR_IP

# Microsoft (needs HTTPS in production); optional if using local-only auth in frontend.
# MS_CLIENT_ID=
# MS_TENANT_ID=
# MS_CLIENT_SECRET=
# MS_REDIRECT_URI=https://YOUR_DOMAIN/auth/microsoft/callback
