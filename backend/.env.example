# Copy to backend/.env for local Mac development with native PostgreSQL.
# Docker Compose overrides these DB values for container deployment.

PORT=5001
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_NAME=timesheet
DB_USER=postgres
DB_PASSWORD=postgres

APP_JWT_SECRET=change-me-to-a-long-random-string

# Optional: comma-separated extra allowed origins (merged with CLIENT_URL). Never use * with credentials.
# CORS_ORIGINS=http://18.232.85.119,http://localhost:5173

CLIENT_URL=http://localhost:5173

# Microsoft (needs HTTPS in production); optional if using local-only auth in frontend.
# MS_CLIENT_ID=
# MS_TENANT_ID=
# MS_CLIENT_SECRET=
# MS_REDIRECT_URI=http://localhost:5173
